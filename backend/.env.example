# Copy this file to ".env" (same folder as this file) and fill in real values.
# Never commit the real ".env" to version control.

# --- App ---
APP_NAME=PaySim Fraud Prevention API
APP_VERSION=4.0.0
ENV=development

# --- Database ---
# Local/dev (SQLite, zero setup):
DATABASE_URL=sqlite:///./paysim_backend.db
# Production (PostgreSQL) example:
# DATABASE_URL=postgresql+psycopg2://paysim_user:CHANGE_ME@localhost:5432/paysim_db

# --- JWT ---
# Generate a real one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_super_secret_key_min_32_chars_long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Project root: point this at wherever the Google Drive target folder tree
# (ID 1ZKZfZRv2xWU9lK9zYYsao16dQRKRCG9f) is actually mounted/synced on THIS
# machine -- e.g. a Colab `drive.mount('/content/drive')` gives
# "/content/drive/MyDrive/Remote_Root_Folder", an rclone/gdown sync gives
# whatever local path you synced it to. Every artifact path below (artifacts/
# phase1, artifacts/phase2, artifacts/phase3/models, ...) is resolved relative
# to this ONE setting -- nothing else needs to change, and no file under it is
# ever renamed or moved.
PROJECT_ROOT=.

# --- Risk routing thresholds (0-100 scale) ---
LOW_RISK_MAX=30
MODERATE_RISK_MAX=60

# --- CORS (comma-separated in real deployments behind a proxy that splits this) ---
CORS_ORIGINS=["*"]
